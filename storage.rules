rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Logo uploads ──────────────────────────────────────────────────────────
    // Only authenticated users who own the barbershop can write logos
    match /logos/{barbershopId}/{allPaths=**} {
      allow read: if true; // Public read (logos are displayed publicly)
      allow write: if request.auth != null
        && request.auth.uid != null;
    }

    // Default: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
